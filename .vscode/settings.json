{
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.defaultConfigurationProvider": "ms-vscode.cpptools",
    "C_Cpp.defaultCompileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.intelliSenseUpdateOnType": "enabled",
    "C_Cpp.enhancedColorization": "enabled",
    "C_Cpp.intelliSenseCacheSize": 512,
    "C_Cpp.intelliSenseMemoryLimit": 4096,
    "editor.suggestOnTriggerCharacters": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    "editor.acceptSuggestionOnEnter": "on",
    "editor.parameterHints.enabled": true,
    "cmake.configureOnOpen": false
}
